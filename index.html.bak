        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "tertiary-fixed-dim": "#aec9ea",
                        "on-secondary": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "surface-container": "#ebeef4",
                        "on-primary": "#ffffff",
                        "inverse-on-surface": "#eef1f7",
                        "secondary-fixed": "#d0e5f8",
                        "surface": "#f7f9ff",
                        "primary-container": "#007cb3",
                        "surface-container-high": "#e5e8ee",
                        "inverse-primary": "#8ccdff",
                        "on-error-container": "#93000a",
                        "on-surface-variant": "#3f4850",
                        "surface-bright": "#f7f9ff",
                        "on-primary-container": "#fcfcff",
                        "background": "#f7f9ff",
                        "on-secondary-fixed": "#081d2b",
                        "on-tertiary-fixed-variant": "#2e4964",
                        "on-primary-fixed-variant": "#004b6f",
                        "primary": "#00628f",
                        "on-tertiary": "#ffffff",
                        "secondary-container": "#d0e5f8",
                        "inverse-surface": "#2d3135",
                        "primary-fixed-dim": "#8ccdff",
                        "on-secondary-container": "#536777",
                        "outline-variant": "#bec7d1",
                        "outline": "#6f7881",
                        "error": "#ba1a1a",
                        "secondary": "#4d6170",
                        "surface-dim": "#d7dae0",
                        "on-primary-fixed": "#001e2f",
                        "tertiary": "#445e7b",
                        "tertiary-fixed": "#d0e4ff",
                        "on-tertiary-container": "#fdfcff",
                        "surface-variant": "#dfe3e8",
                        "secondary-fixed-dim": "#b4c9db",
                        "on-secondary-fixed-variant": "#354958",
                        "on-background": "#181c20",
                        "surface-container-highest": "#dfe3e8",
                        "surface-container-low": "#f1f4fa",
                        "tertiary-container": "#5d7794",
                        "primary-fixed": "#cae6ff",
                        "surface-tint": "#006492",
                        "on-surface": "#181c20",
                        "on-tertiary-fixed": "#001d35"
                    },
                    fontFamily: {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Work Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .asymmetric-hero {
            clip-path: polygon(0 0, 100% 0, 100% 85%, 0% 100%);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
    <div id="root"></div>

    <!-- React Library CDN Links -->
    <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/history@5/umd/history.development.js"></script>
    <script src="https://unpkg.com/react-router@6.3.0/umd/react-router.development.js"></script>
    <script src="https://unpkg.com/react-router-dom@6.3.0/umd/react-router-dom.development.js"></script>
    <script src="https://unpkg.com/babel-standalone@6/babel.min.js"></script>

    <script type="text/babel">
        const { useState, useEffect } = React;
        const { createRoot } = ReactDOM;
        const { MemoryRouter, Routes, Route, Link, useNavigate, useLocation } = ReactRouterDOM;

        // --- Shared Components ---

        const Layout = ({ children }) => {
            const location = useLocation();
            const navigate = useNavigate();
            const isActive = (path) => location.pathname === path;

            return (
                <div className="flex flex-col min-h-screen">
                    <nav className="fixed top-0 w-full z-50 glass-nav shadow-[0_12px_32px_rgba(24,28,32,0.06)]">
                        <div className="flex justify-between items-center max-w-7xl mx-auto px-8 h-20">
                            <Link to="/" className="flex items-center gap-3">
                                <img alt="Logo" className="h-10 w-auto" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXi_Om7QSPsllAaThlUGAT1rQ1GBjjKr0ZUgOiY_DBEacOvysoG-sw9iOgp5_FTKlsBa113Mv273wHugza6jt3zbyXNZw68HPnuqDCVU91zjJNDDbDAW4Y3IRbPZmH-CoVX14zb1tmwZKQ1-IKl8mkNLnQFaXFqYeHsNSG0FXWp-2a1dy1FbEs1JB-rLjEsnvdNy8fC18SKnH2LpU4fiJDtg59eEs1jUZfuFhTRh9p48TUJY7yG7gkMCUlGP1I_RpR3bm7famj_H0" />
                                <span className="text-xl font-bold text-[#00628f] font-headline hidden sm:inline">Keyport Logistic Lines</span>
