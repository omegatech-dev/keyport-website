                                    <img className="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC1cW-F7xK4A2kni5hqEmPQRxnw1N6InWRec50jDPS5HLF2aN4N-Xf1h7Djn5zN-eMhZhllQ2RrH5UY1Nyr0yNnDaHhMB5oAn1te2OJiE5UFYWGl5aAYV7AAo_N0zOlG0jO9T-PG4fJ3bBSBelY-dlZ4O4eNSB04zroVtfvXVQ5W03rJqE4swQuiiFbIruJIBYniyEh0E3l2I7KknT6Z4NplWl9bTDmLNFAu9Qtlg-ENLvEMn7De0eJXlhffDjA_VyhpaXcx6ENacY" />
                                </div>
                            </div>
                            <div className="md:col-span-4 bg-surface-container-low p-8 rounded-xl flex flex-col justify-between">
