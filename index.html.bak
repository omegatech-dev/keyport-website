                                <Link className={`${isActive('/') ? 'text-[#00628f] border-b-2 border-[#00628f] pb-1' : 'text-slate-600 hover:text-[#00628f] transition-colors'}`} to="/">Home</Link>
                                <Link className={`${isActive('/services') ? 'text-[#00628f] border-b-2 border-[#00628f] pb-1' : 'text-slate-600 hover:text-[#00628f] transition-colors'}`} to="/services">Services</Link>
                                <Link className={`${isActive('/about') ? 'text-[#00628f] border-b-2 border-[#00628f] pb-1' : 'text-slate-600 hover:text-[#00628f] transition-colors'}`} to="/about">About Us</Link>
                                <Link className={`${isActive('/contact') ? 'text-[#00628f] border-b-2 border-[#00628f] pb-1' : 'text-slate-600 hover:text-[#00628f] transition-colors'}`} to="/contact">Contact</Link>
