                                    <span className="font-label text-xs font-bold text-primary">COBERTURA NACIONAL (EE.UU.)</span>
                                </div>
                            </div>
                            <div className="md:col-span-4 bg-primary text-on-primary p-8 rounded-xl">
                                <span className="material-symbols-outlined text-primary-fixed text-4xl mb-4">description</span>
                                <h3 className="font-headline text-xl font-bold mb-3">Gestión de Aforo</h3>
                                <p className="text-white/80 text-sm mb-6">Manejamos toda la documentación aduanal y trámites de importación.</p>
                            </div>
                        </div>
                    </section>
                </div>
            );
        };

        // --- Screen 3: About Us ---
        const AboutPage = () => (
            <div className="animate-in fade-in duration-500">
                <section className="relative h-[600px] flex items-center overflow-hidden">
                    <div className="absolute inset-0 z-0">
                        <img alt="Background" className="w-full h-full object-cover grayscale-[20%] brightness-[40%]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAHtuJXjdVSelRTRisD8HCQREMewyxQ2odWFXgoo1NRwjw1ckNMK7Ik262ZQgsTOmQrbBpox8ZDPJ2Iha6qVmvsuiGdW1qDt8xtiKHKRIoZ-_nxDBR3gHS-Nx4r3fZdBfyxLVJZgwbS0nzNU3PyFOLeOJh6uzBN-crah6yrBkl2TqQSGUzF_vJickznJ1pJr-BZexvYbvT-5VurBBs9nlYd8RKss-WL7oBh74uirVHo5ThnsSJm0L3v6rM0begGAfEY6lljXMUqFjc" />
                    </div>
                    <div className="container mx-auto px-8 relative z-10">
                        <div className="max-w-3xl">
                            <span className="inline-block py-1 px-3 bg-primary/20 text-primary-fixed font-label text-sm font-semibold tracking-wider rounded-full mb-6 uppercase">Sobre Nosotros</span>
                            <h1 className="text-6xl md:text-8xl font-black text-white font-headline leading-tight tracking-tighter mb-8">Nuestra <span className="text-primary-fixed">Historia.</span></h1>
                        </div>
                    </div>
                </section>
                <section className="py-24 bg-surface">
                    <div className="container mx-auto px-8">
                        <div className="flex flex-col lg:flex-row gap-16 items-start">
                            <div className="lg:w-1/2">
                                <h2 className="text-4xl font-black text-on-surface font-headline tracking-tighter mb-8">Raíces de Excelencia</h2>
                                <p className="text-on-surface-variant text-lg leading-relaxed mb-6">Keyport Logistic Lines nació de una visión clara: simplificar la complejidad del comercio internacional de vehículos. Bajo el liderazgo de Keylin Orellana, hemos construido una red que traslada confianza.</p>
                            </div>
                            <div className="lg:w-1/2 grid grid-cols-2 gap-4">
                                <div className="bg-surface-container-low rounded-xl p-8 flex flex-col justify-center aspect-square">
                                    <span className="text-5xl font-black text-primary mb-2 tracking-tighter">15+</span>
                                    <span className="font-label text-on-secondary-container uppercase tracking-widest text-xs font-bold">Años de Experiencia</span>
                                </div>
                                <div className="bg-primary rounded-xl p-8 flex flex-col justify-center aspect-square text-on-primary">
                                    <span className="text-5xl font-black mb-2 tracking-tighter">5k+</span>
                                    <span className="font-label uppercase tracking-widest text-xs font-bold">Vehículos Importados</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <section className="py-24 bg-surface-container-low">
                    <div className="container mx-auto px-8">
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/20 rounded-2xl overflow-hidden">
                            <div className="bg-white p-12 hover:bg-primary hover:text-white transition-all duration-500 group">
                                <h3 className="text-3xl font-black font-headline mb-6">Misión</h3>
                                <p className="text-lg opacity-80">Proveer soluciones logísticas de vanguardia que garanticen la seguridad y eficiencia en cada importación.</p>
                            </div>
                            <div className="bg-white p-12 hover:bg-primary hover:text-white transition-all duration-500 group">
                                <h3 className="text-3xl font-black font-headline mb-6">Visión</h3>
                                <p className="text-lg opacity-80">Ser el referente indiscutible en logística de vehículos para el corredor EE.UU. - Centroamérica.</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        );

        // --- Screen 4: Contact ---
        const ContactPage = () => {
            const [submitted, setSubmitted] = useState(false);
            const handleSubmit = (e) => {
                e.preventDefault();
                setSubmitted(true);
                setTimeout(() => setSubmitted(false), 3000);
            };

            return (
                <div className="animate-in fade-in duration-500">
                    <section className="relative h-[400px] flex items-center overflow-hidden">
                        <div className="absolute inset-0 z-0">
                            <img alt="Contact" className="w-full h-full object-cover grayscale brightness-[0.3]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMrwll8LSTZlnk9Wyf5mA4yvjDEae47tGSaFzjmdl19-pXur0W57-vN4enzvtBKSjMVUd-MXdvN90iBZbevg7AEh3yt0i3OP6zDcGXQPoswIydCuza8WFRzoneAYBGhABRqCAYYoAxEAcdmoigGJe8KMY_78ANfvNAkwb-BqWmIwrNECo5ywIsbTtCn4vz7UdMkNq7lopqiwzxtwSoKiCnYWDeWogkw89mD5izfNewtitumREa8NGPW7Rtqtj1rl6koOXB-4ecbcc" />
                        </div>
                        <div className="relative z-10 max-w-7xl mx-auto px-8 w-full">
                            <h1 className="text-5xl md:text-7xl font-headline font-extrabold text-white tracking-tight">Contáctanos</h1>
                        </div>
                    </section>
                    <section className="max-w-7xl mx-auto px-8 py-20 grid grid-cols-1 lg:grid-cols-12 gap-12">
                        <div className="lg:col-span-5 space-y-8">
                            <h2 className="text-3xl font-headline font-bold">Información de Enlace</h2>
                            <div className="p-8 bg-surface-container-low rounded-xl border-l-4 border-primary">
                                <div className="flex items-start gap-4">
                                    <span className="material-symbols-outlined text-primary text-3xl">location_on</span>
                                    <div>
                                        <h3 className="font-headline font-bold text-lg mb-1">Nuestra Sede</h3>
                                        <p className="text-on-surface-variant">Bo. Centro, Puerto Cortés, Honduras.</p>
                                    </div>
                                </div>
                            </div>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div className="p-8 bg-surface-container-low rounded-xl">
                                    <span className="material-symbols-outlined text-primary text-3xl mb-4">call</span>
                                    <h3 className="font-headline font-bold text-lg mb-2">Teléfonos</h3>
                                    <p className="text-sm font-semibold">8921-3401 / 8777-0513</p>
                                </div>
                                <div className="p-8 bg-surface-container-low rounded-xl">
                                    <span className="material-symbols-outlined text-primary text-3xl mb-4">mail</span>
                                    <h3 className="font-headline font-bold text-lg mb-2">Email</h3>
                                    <p className="text-xs break-all">gerencia@keyportlogisticlines.com</p>
                                </div>
                            </div>
                        </div>
                        <div className="lg:col-span-7">
                            <div className="bg-white p-10 rounded-xl shadow-sm border border-outline-variant/10">
                                <form className="space-y-6" onSubmit={handleSubmit}>
                                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <input className="w-full bg-surface-container-low p-4 rounded focus:ring-primary focus:border-primary border-none" placeholder="Nombre Completo" type="text" required />
                                        <input className="w-full bg-surface-container-low p-4 rounded focus:ring-primary focus:border-primary border-none" placeholder="Correo Electrónico" type="email" required />
                                    </div>
                                    <textarea className="w-full bg-surface-container-low p-4 rounded focus:ring-primary focus:border-primary border-none" placeholder="Mensaje..." rows="4" required></textarea>
                                    <button className="w-full bg-primary text-on-primary py-4 rounded-lg font-headline font-bold hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                        {submitted ? 'Enviado!' : 'Enviar Solicitud'}
                                        <span className="material-symbols-outlined">send</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </section>
                </div>
            );
        };

        // --- Screen 5: Quote ---
        const QuotePage = () => {
            const [step, setStep] = useState(1);
            const nextStep = () => setStep(s => Math.min(s + 1, 3));

            return (
                <div className="animate-in fade-in duration-500">
                    <section className="bg-primary py-20 asymmetric-hero">
                        <div className="max-w-7xl mx-auto px-8 text-white">
                            <h1 className="text-4xl md:text-6xl font-extrabold mb-6 font-headline tracking-tighter">Solicita tu Cotización</h1>
                            <p className="text-lg opacity-90 max-w-xl">Calculamos los costos exactos para que tu vehículo llegue sin sorpresas.</p>
                        </div>
                    </section>
                    <section className="max-w-7xl mx-auto px-8 -mt-16 relative z-10 pb-24">
                        <div className="bg-white rounded-xl shadow-xl overflow-hidden grid lg:grid-cols-12">
                            <div className="lg:col-span-4 bg-surface-container-low p-10">
                                <h3 className="text-2xl font-bold mb-8">Guía de Solicitud</h3>
                                <div className="space-y-8">
                                    <div className={`flex gap-4 ${step === 1 ? 'text-primary' : 'text-slate-400'}`}>
                                        <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold border ${step >= 1 ? 'border-primary bg-primary text-white' : 'border-slate-300'}`}>1</div>
                                        <div><h4 className="font-bold">Contacto</h4></div>
                                    </div>
                                    <div className={`flex gap-4 ${step === 2 ? 'text-primary' : 'text-slate-400'}`}>
                                        <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold border ${step >= 2 ? 'border-primary bg-primary text-white' : 'border-slate-300'}`}>2</div>
                                        <div><h4 className="font-bold">Vehículo</h4></div>
                                    </div>
                                    <div className={`flex gap-4 ${step === 3 ? 'text-primary' : 'text-slate-400'}`}>
                                        <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold border ${step >= 3 ? 'border-primary bg-primary text-white' : 'border-slate-300'}`}>3</div>
                                        <div><h4 className="font-bold">Destino</h4></div>
                                    </div>
                                </div>
                            </div>
                            <div className="lg:col-span-8 p-10 md:p-16">
                                <div className="space-y-8">
                                    {step === 1 && (
                                        <div className="space-y-6 animate-in slide-in-from-right-4 duration-300">
                                            <h2 className="text-2xl font-bold border-b pb-4">Información Personal</h2>
                                            <div className="grid md:grid-cols-2 gap-6">
                                                <input className="bg-surface-container-low p-3 rounded w-full border-none" placeholder="Nombre Completo" />
                                                <input className="bg-surface-container-low p-3 rounded w-full border-none" placeholder="Email" />
                                            </div>
                                            <button onClick={nextStep} className="bg-primary text-white px-8 py-3 rounded font-bold">Continuar</button>
                                        </div>
                                    )}
                                    {step === 2 && (
                                        <div className="space-y-6 animate-in slide-in-from-right-4 duration-300">
                                            <h2 className="text-2xl font-bold border-b pb-4">Detalles del Vehículo</h2>
                                            <div className="grid md:grid-cols-3 gap-4">
                                                <input className="bg-surface-container-low p-3 rounded w-full border-none" placeholder="Año" />
                                                <input className="bg-surface-container-low p-3 rounded w-full border-none" placeholder="Marca" />
                                                <input className="bg-surface-container-low p-3 rounded w-full border-none" placeholder="Modelo" />
                                            </div>
                                            <button onClick={nextStep} className="bg-primary text-white px-8 py-3 rounded font-bold">Continuar</button>
                                        </div>
                                    )}
                                    {step === 3 && (
                                        <div className="space-y-6 animate-in slide-in-from-right-4 duration-300">
                                            <h2 className="text-2xl font-bold border-b pb-4">Destino y Servicio</h2>
                                            <select className="bg-surface-container-low p-3 rounded w-full border-none">
                                                <option>Logística Integral (All-in)</option>
                                                <option>Aforo y Aduanas</option>
                                            </select>
                                            <div className="flex gap-4">
                                                <label className="flex-1 p-4 border rounded cursor-pointer hover:bg-slate-50">
                                                    <input type="radio" name="dest" className="mr-2" /> Honduras
                                                </label>
                                                <label className="flex-1 p-4 border rounded cursor-pointer hover:bg-slate-50">
                                                    <input type="radio" name="dest" className="mr-2" /> Guatemala
                                                </label>
                                            </div>
                                            <button onClick={() => alert('Solicitud enviada!')} className="bg-primary text-white px-8 py-3 rounded font-bold">Enviar Solicitud</button>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            );
        };

        // --- Main App Component ---
        const App = () => {
            return (
                <MemoryRouter>
                    <Layout>
                        <Routes>
                            <Route path="/" element={<HomePage />} />
                            <Route path="/services" element={<ServicesPage />} />
                            <Route path="/about" element={<AboutPage />} />
                            <Route path="/contact" element={<ContactPage />} />
                            <Route path="/quote" element={<QuotePage />} />
                        </Routes>
                    </Layout>
                </MemoryRouter>
            );
        };

        // --- Render ---
        const container = document.getElementById('root');
        const root = createRoot(container);
        root.render(<App />);
    </script>
</body>

</html>